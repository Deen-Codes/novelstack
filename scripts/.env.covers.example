# NovelStack cover uploader — credentials.
#
# Copy this file to `.env.covers` (no .example) and fill in the real values.
# `.env.covers` is gitignored so credentials don't leak into the repo.
#
# Where to get each value:
#   DATABASE_URL          — Render dashboard → Postgres service → Connect →
#                           External Database URL
#   R2_ENDPOINT           — Render dashboard → web service → Environment
#   R2_ACCESS_KEY_ID      — same
#   R2_SECRET_ACCESS_KEY  — same
#   R2_BUCKET             — same (probably 'novelstack-covers')
#   NEXT_PUBLIC_SITE_URL  — same (probably 'https://novelstack.app')
#
# Once filled in, run from the repo root:
#   node scripts/upload-covers.mjs
# No command-line env vars needed.

DATABASE_URL=postgresql://novelstack_db_user:PASSWORD@HOST.oregon-postgres.render.com/novelstack_db
R2_ENDPOINT=https://YOUR-ACCOUNT-ID.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=YOUR-R2-ACCESS-KEY
R2_SECRET_ACCESS_KEY=YOUR-R2-SECRET
R2_BUCKET=novelstack-covers
NEXT_PUBLIC_SITE_URL=https://novelstack.app
