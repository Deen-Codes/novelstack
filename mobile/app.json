{
  "expo": {
    "name": "NovelStack",
    "slug": "novelstack",
    "version": "0.1.0",
    "scheme": "novelstack",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "backgroundColor": "#F5EFE0",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.novelstack",
      "buildNumber": "1",
      "infoPlist": {
        "LSApplicationQueriesSchemes": [
          "message",
          "googlegmail",
          "ms-outlook",
          "ymail",
          "readdle-spark"
        ]
      }
    },
    "android": {
      "package": "app.novelstack",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F5EFE0"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": ["expo-router"],
    "experiments": { "typedRoutes": true },
    "extra": {
      "supabaseUrl": "https://kgjstbfgqzxxtyjidapq.supabase.co",
      "supabaseAnonKey": "sb_publishable_KU1-3JfXO5aD5z00GKQ2dw_0K8oR3am"
    }
  }
}
