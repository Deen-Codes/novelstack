{
  "expo": {
    "name": "NovelStack",
    "slug": "novelstack",
    "version": "0.1.0",
    "scheme": "novelstack",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "backgroundColor": "#F5EFE0",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.novelstack",
      "buildNumber": "1",
      "infoPlist": {
        "LSApplicationQueriesSchemes": [
          "message",
          "googlegmail",
          "ms-outlook",
          "ymail",
          "protonmail",
          "fastmail",
          "readdle-spark",
          "airmail"
        ]
      }
    },
    "android": {
      "package": "app.novelstack",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F5EFE0"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "NovelStack needs access to your photos so you can choose a cover image for your story."
        }
      ]
    ],
    "experiments": { "typedRoutes": true },
    "extra": {
      "apiBaseUrl": "https://novelstack.onrender.com"
    }
  }
}
