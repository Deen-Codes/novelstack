{
  "expo": {
    "name": "NovelStack",
    "slug": "novelstack",
    "version": "0.1.0",
    "scheme": "novelstack",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "backgroundColor": "#14110F",
      "resizeMode": "cover"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.novelstack",
      "buildNumber": "6",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "NovelStack needs access to your photos so you can choose a cover image for your story.",
        "LSApplicationQueriesSchemes": [
          "message",
          "googlegmail",
          "ms-outlook",
          "ymail",
          "protonmail",
          "fastmail",
          "readdle-spark",
          "airmail"
        ]
      }
    },
    "android": {
      "package": "app.novelstack",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#14110F"
      },
      "permissions": [
        "com.google.android.gms.permission.AD_ID"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "./plugins/with-silent-pod-warnings.js",
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "NovelStack needs access to your photos so you can choose a cover image for your story.",
          "cameraPermission": "NovelStack uses the camera so you can take a photo to use as your story cover.",
          "microphonePermission": false
        }
      ],
      [
        "expo-tracking-transparency",
        {
          "userTrackingPermission": "NovelStack uses this to show ads that are more relevant to you. Your data is never sold."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#C8414E"
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "iosAppId": "ca-app-pub-4785473067647076~8254338656",
          "androidAppId": "ca-app-pub-4785473067647076~7241851333"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiBaseUrl": "https://www.novelstack.app",
      "revenueCatKey": "appl_ZXUWIahuvhxnAIYzlPrSGdhlWGN",
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "7eee7704-58a1-477f-82ae-d11d21bc220f"
      }
    },
    "runtimeVersion": "1.0.0",
    "updates": {
      "url": "https://u.expo.dev/7eee7704-58a1-477f-82ae-d11d21bc220f"
    }
  }
}
