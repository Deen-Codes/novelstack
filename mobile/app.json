{
  "expo": {
    "name": "NovelStack",
    "slug": "novelstack",
    "version": "0.1.0",
    "scheme": "novelstack",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "backgroundColor": "#14110F",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.novelstack",
      "buildNumber": "1",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "NovelStack needs access to your photos so you can choose a cover image for your story.",
        "LSApplicationQueriesSchemes": [
          "message",
          "googlegmail",
          "ms-outlook",
          "ymail",
          "protonmail",
          "fastmail",
          "readdle-spark",
          "airmail"
        ]
      }
    },
    "android": {
      "package": "app.novelstack",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#14110F"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "NovelStack needs access to your photos so you can choose a cover image for your story."
        }
      ],
      [
        "expo-tracking-transparency",
        {
          "userTrackingPermission": "NovelStack uses this to show ads that are more relevant to you. Your data is never sold."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#C8414E"
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "iosAppId": "ca-app-pub-4785473067647076~8254338656",
          "androidAppId": "ca-app-pub-4785473067647076~7241851333"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiBaseUrl": "https://novelstack.onrender.com",
      "revenueCatKey": "appl_ZXUWIahuvhxnAIYzlPrSGdhlWGN"
    }
  }
}
