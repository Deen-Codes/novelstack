# NovelStack web — environment variables.
# Copy to .env.local and fill in. On Render, set these in the service's
# Environment settings instead.

# Render PostgreSQL connection string (Render dashboard → your database →
# "Internal Database URL" for the deployed service, "External Database URL"
# for local dev / migrations).
DATABASE_URL=

# Resend API key — used to send magic-link sign-in emails.
RESEND_API_KEY=

# Secret used to sign session JWTs. Generate with: openssl rand -base64 32
AUTH_SECRET=

# Public base URL of the site (used in magic-link emails and cover URLs).
NEXT_PUBLIC_SITE_URL=https://novelstack.app

# --- Cloudflare R2 — object storage for author-uploaded book covers ---
# Endpoint is https://<account-id>.r2.cloudflarestorage.com
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=novelstack-covers

# --- RevenueCat — server-to-server webhook for NovelStack+ subscriptions ---
# A long random string; set the same value as the Authorization header on the
# RevenueCat webhook. Until set, the webhook accepts all requests.
REVENUECAT_WEBHOOK_SECRET=

# --- Stripe — author payouts via Stripe Connect ---
# The platform account's secret key (Stripe dashboard → Developers → API keys).
# Requires a verified Stripe platform account (registered business: LLC/EIN +
# bank). Until this is set, the earnings dashboard still works read-only and
# payout setup shows "coming soon".
STRIPE_SECRET_KEY=
